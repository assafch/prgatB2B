# === Server ===
PORT=3030
# NODE_ENV is set by the runtime (npm start sets production). Never put it here:
# vite build reads this file and NODE_ENV=development would strip PROD-only code
# (e.g. the service-worker registration) out of the client bundle.
APP_BASE_URL=http://localhost:5173

# === Session ===
# 32+ random bytes (openssl rand -hex 32)
SESSION_SECRET=replace_with_random_hex

# === Data directory (persistent volume on Railway) ===
DATA_DIR=./data

# === Priority ERP (Orgat cloud) ===
PRIORITY_BASE_URL=https://p.priority-connect.online/odata/Priority/tabp008h.ini
PRIORITY_COMPANY=a051014
PRIORITY_PAT=replace_with_pat

# === Admin bootstrap (first run only — used when users table is empty) ===
ADMIN_BOOTSTRAP_USERNAME=assaf
ADMIN_BOOTSTRAP_PASSWORD=replace_with_strong_password

# === Card payments (PSP) ===
# Card payment stays dark until payments_enabled is on (admin setting / PAYMENTS_ENABLED)
# AND a provider is configured. CARD_PROVIDER picks the active PSP: upay | tranzila | payplus.
CARD_PROVIDER=payplus

# --- PayPlus (card PSP option 3) — server-side REST API v1.0 ---
# All values come from the PayPlus dashboard (Settings > Devices). Real values go in
# .env only (gitignored); never commit them. api-key/secret-key are sent as HTTP headers
# and the secret also verifies the inbound webhook HMAC.
PAYPLUS_ENV=staging                  # staging (restapidev) | prod (restapi). Default prod.
PAYPLUS_API_KEY=replace_with_api_key
PAYPLUS_SECRET_KEY=replace_with_secret_key
PAYPLUS_PAGE_UID=replace_with_payment_page_uid
PAYPLUS_TERMINAL_UID=replace_with_terminal_uid   # reference only (bound to the page)
PAYPLUS_CASHIER_UID=replace_with_cashier_uid     # optional — attributes the sale
PAYPLUS_DEVICE_UID=replace_with_device_uid       # reference only
PAYPLUS_FALLBACK_EMAIL=office@orgat.co.il         # used if the Priority customer has no email
