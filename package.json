{
  "name": "prgat-b2b",
  "version": "0.1.0",
  "description": "B2B self-order portal for Orgat Sahar — Priority ERP, Hebrew RTL PWA",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@types/multer": "^2.1.0",
    "@types/papaparse": "^5.5.2",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.0",
    "multer": "^2.2.0",
    "papaparse": "^5.5.3",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
